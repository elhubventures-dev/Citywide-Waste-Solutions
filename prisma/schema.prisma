// ─── Prisma Schema ─────────────────────────────────────────────────────────────
// Citywide Waste Solutions — PostgreSQL via Supabase

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum SubmissionType {
  QUOTE
  CONTACT
  NEWSLETTER
}

enum SubmissionStatus {
  NEW
  READ
  REPLIED
  ARCHIVED
}

enum ServiceType {
  RESIDENTIAL_WASTE_COLLECTION
  COMMERCIAL_WASTE_MANAGEMENT
  RECYCLING_SERVICES
  DUMPSTER_BIN_RENTAL
  JUNK_REMOVAL
  CONSTRUCTION_WASTE_REMOVAL
}

enum InvoiceStatus {
  DRAFT
  PENDING
  SENT
  VIEWED
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
  REFUNDED
}

enum UserRole {
  OWNER
  ADMIN
  EDITOR
}

// ─── Models ───────────────────────────────────────────────────────────────────

model QuoteRequest {
  id               String          @id @default(cuid())
  fullName         String
  email            String
  phone            String
  serviceType      ServiceType
  city             String
  pickupFrequency  String?
  message          String?         @db.Text
  smsOptIn         Boolean         @default(false)
  status           SubmissionStatus @default(NEW)
  ipAddress        String?
  userAgent        String?
  crmContactId     String?         // GoHighLevel contact ID
  crmPipelineId    String?
  notes            String?         @db.Text
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@map("quote_requests")
  @@index([status])
  @@index([email])
  @@index([createdAt])
}

model ContactSubmission {
  id           String          @id @default(cuid())
  fullName     String
  email        String
  phone        String?
  subject      String
  message      String          @db.Text
  status       SubmissionStatus @default(NEW)
  ipAddress    String?
  userAgent    String?
  notes        String?         @db.Text
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@map("contact_submissions")
  @@index([status])
  @@index([email])
}

model NewsletterSubscriber {
  id          String    @id @default(cuid())
  email       String    @unique
  name        String?
  isActive    Boolean   @default(true)
  source      String?   // "footer", "blog", "popup"
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("newsletter_subscribers")
  @@index([isActive])
}

model Client {
  id              String    @id @default(cuid())
  company         String?
  name            String?
  email           String?
  phone           String?
  serviceAddress  String?
  billingAddress  String?
  city            String?
  province        String?
  country         String?   @default("Canada")
  zip             String?
  taxNumber       String?
  notes           String?   @db.Text
  
  invoices        Invoice[]
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("clients")
}

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique
  issueDate     String?
  dueDate       String?
  currency      String        @default("CAD")
  terms         String?       @db.Text
  status        String        @default("Draft")
  brand         String        @default("waste")
  type          String        @default("INVOICE") // "INVOICE" or "QUOTE"
  
  // Totals & Payments
  subtotal      Float         @default(0)
  discountTotal Float         @default(0)
  taxTotal      Float         @default(0)
  grandTotal    Float         @default(0)
  deposit       Float         @default(0)
  amountPaid    Float         @default(0)
  balanceDue    Float         @default(0)

  // Relations
  clientId      String
  client        Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  items         InvoiceItem[]
  activities    InvoiceActivity[]

  stripePaymentIntentId String? @unique
  paidAt        DateTime?

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("invoices")
  @@index([status])
  @@index([invoiceNumber])
  @@index([clientId])
}

model InvoiceItem {
  id          String   @id @default(cuid())
  service     String
  description String?  @db.Text
  qty         Float    @default(1)
  unit        String   @default("unit")
  price       Float    @default(0)
  discount    Float    @default(0)
  tax         Float    @default(13)

  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_items")
  @@index([invoiceId])
}

model InvoiceActivity {
  id        String   @id @default(cuid())
  action    String   // "CREATED", "SENT", "VIEWED", "PAID", "UPDATED"
  notes     String?  @db.Text
  createdAt DateTime @default(now())

  invoiceId String
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_activities")
  @@index([invoiceId])
  @@index([createdAt])
}

model AdminUser {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String
  role      UserRole  @default(EDITOR)
  clerkId   String?   @unique
  isActive  Boolean   @default(true)
  lastLogin DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("admin_users")
}

model SmsLog {
  id          String    @id @default(cuid())
  to          String
  body        String    @db.Text
  twilioSid   String?
  status      String    // "queued" | "sent" | "delivered" | "failed"
  refType     String?   // "quote" | "pickup_reminder" | "confirmation"
  refId       String?
  createdAt   DateTime  @default(now())

  @@map("sms_logs")
  @@index([to])
  @@index([status])
}

model PickupSchedule {
  id          String    @id @default(cuid())
  quoteId     String
  customerName String
  phone        String
  address      String
  city         String
  serviceType  ServiceType
  scheduledDate DateTime
  frequency    String?   // "weekly" | "biweekly" | "monthly" | "onetime"
  notes        String?
  isCompleted  Boolean   @default(false)
  completedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("pickup_schedules")
  @@index([scheduledDate])
  @@index([isCompleted])
}
